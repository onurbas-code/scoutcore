generator client { provider = "prisma-client-js" }
datasource db { provider = "sqlite"; url = env("DATABASE_URL") }

enum PlayerStatus { A_TARGET B_TARGET C_WATCH WATCHING REJECTED }
enum PositionGroup { KALECI STOPER SOL_BEK SAG_BEK ORTA_SAHA KANAT FORVET }
enum TransferFolder { ACIL_TRANSFER GELECEK_SEZON GELISIM_OYUNCULARI KIRALIK SOZLESMESI_BITECEKLER SERBEST_OYUNCULAR TAKIP_LISTESI }
enum TransferStage { WATCHING LIVE_SCOUTING SECOND_SCOUTING VIDEO_ANALYSIS TECHNICAL_DIRECTOR_REVIEW TRANSFER_COMMITTEE OFFER COMPLETED REJECTED }

model Player {
  id String @id @default(cuid())
  name String
  photoUrl String?
  age Int?
  position String?
  positionGroup PositionGroup @default(ORTA_SAHA)
  transferFolder TransferFolder @default(TAKIP_LISTESI)
  club String?
  league String?
  nationality String?
  contractEnd String?
  apps Int @default(0)
  goals Int @default(0)
  assists Int @default(0)
  minutes Int @default(0)
  technical Int @default(7)
  tactical Int @default(7)
  physical Int @default(7)
  mental Int @default(7)
  transferScore Int @default(70)
  status PlayerStatus @default(WATCHING)
  stage TransferStage @default(WATCHING)
  clubInterest String?
  reports Report[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Report {
  id String @id @default(cuid())
  playerId String
  match String?
  report String
  strengths String?
  weaknesses String?
  action String?
  decision String?
  createdAt DateTime @default(now())
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}
